{
  "name": "openclaw-taskboard-cli",
  "version": "0.1.2",
  "description": "Terminal CLI for openclaw taskboard — direct MongoDB access, zero HTTP",
  "type": "module",
  "bin": {
    "taskboard": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "bun build --compile --target=bun --outfile=taskboard src/index.ts"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "mongodb": "^6.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.3.11"
  }
}
